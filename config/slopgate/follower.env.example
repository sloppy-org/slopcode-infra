# Slopgate follower-node configuration. Copy to ~/.config/slopgate/follower.env
# and fill in the placeholder values for THIS host and YOUR leader. The real
# file is git-ignored — never commit it.
#
# Followers run only the slopgate-agent service. The agent registers the
# local llama-server with the leader's management endpoint over WireGuard
# (or whatever private network you've put the cluster on).

# --- How this follower talks to the leader ----------------------------------
# The leader's management address. Use the leader's WireGuard / LAN IP, not
# its public hostname.
SLOPGATE_LEADER_MANAGEMENT_ADDR=10.0.0.1:8085

# --- Local llama-server (this host) -----------------------------------------
# How the agent reaches the local llama-server. With LLAMACPP_BIND_LOOPBACK
# the launcher binds 127.0.0.1:8080.
SLOPGATE_LOCAL_LLAMACPP_ADDR=127.0.0.1:8080

# How the leader's balancer reaches this host's llama-server. The agent
# advertises this address to the leader; the balancer connects directly.
# Use this host's WireGuard / LAN IP, not loopback.
SLOPGATE_EXTERNAL_LLAMACPP_ADDR=10.0.0.2:8080

# Friendly name shown in the management UI. Hostname is fine.
SLOPGATE_AGENT_NAME=follower-1

# Capability metadata.
# Native context length llama-server was launched with. Used by the leader's
# KV-headroom filter to skip slots that can't fit a request.
SLOPGATE_MAX_CONTEXT=262144
# Model alias this agent serves; the leader routes by matching this against
# the X-Slopgate-Model header (or X-Slopgate-Session sticky route).
SLOPGATE_MODEL_ALIAS=qwen
