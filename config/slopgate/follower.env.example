# Slopgate follower-node configuration. Copy to ~/.config/slopgate/follower.env
# and fill in the placeholder values for THIS host and YOUR leader. The real
# file is git-ignored — never commit it.
#
# Followers run only the slopgate-agent service. The agent registers the
# local llama-server with the leader's management endpoint over WireGuard
# (or whatever private network you've put the cluster on).

# --- How this follower talks to the leader ----------------------------------
# The leader's management address. Use the leader's WireGuard / LAN IP, not
# its public hostname.
SLOPGATE_LEADER_MANAGEMENT_ADDR=10.0.0.1:8085

# --- Local llama-server (this host) -----------------------------------------
# How the agent reaches the local llama-server. With LLAMACPP_BIND_LOOPBACK
# the launcher binds 127.0.0.1:8080.
SLOPGATE_LOCAL_LLAMACPP_ADDR=127.0.0.1:8080
SLOPGATE_LLAMACPP_REQUEST_TIMEOUT=120

# How the leader's balancer reaches this host's llama-server. The agent
# advertises this address to the leader; the balancer connects directly.
# Use this host's WireGuard / LAN IP, not loopback.
SLOPGATE_EXTERNAL_LLAMACPP_ADDR=10.0.0.2:8080

# Friendly name shown in the management UI. Hostname is fine.
SLOPGATE_AGENT_NAME=follower-1

# Stable class name shared by physically identical hosts. The balancer keys
# pre-calibration EMA seeds by (machine_profile, canonical_model), so a
# fresh follower on the same hardware inherits an existing seed entry on
# first heartbeat instead of paying the cold-start exploration cost.
# Defaults to the host's machine_id when left empty.
SLOPGATE_MACHINE_PROFILE=mac-studio-m3-ultra-256g

# Capability metadata.
# Native context length llama-server was launched with. Used by the leader's
# KV-headroom filter to skip slots that can't fit a request.
SLOPGATE_MAX_CONTEXT=180000

# Canonical model identity at the weights-family + context level
# (vendor/family:size-variant@ctx). Same canonical across quants — the
# SLOPGATE_QUANT field below distinguishes UD-Q4_K_XL from UD-IQ4_XS so
# the dashboard does not flag the per-host quant split as drift.
SLOPGATE_CANONICAL_MODEL=unsloth/qwen3.6:35b-a3b@180k

# Quant label this peer is serving. Informational; not used for routing.
# Linux PC and follower default is UD-IQ4_XS; Mac Studio leader runs
# UD-Q4_K_XL. See ../docs/iq4_xs-rollout.md.
SLOPGATE_QUANT=UD-IQ4_XS

# Short routing name (legacy --model-alias). Used as canonical when
# SLOPGATE_CANONICAL_MODEL is empty.
SLOPGATE_MODEL_ALIAS=qwen

# Comma-separated additional aliases this agent answers to. Order does not
# matter; the proxy accepts any of them in the OpenAI "model" field.
SLOPGATE_MODEL_ALIASES=35b,35b@180k,Q4

# Load-bearing llama-server launch flags that /props does not expose.
# Folded into config_digest so two followers with identical canonical names
# but different KV quant / slot count / batch sizes fingerprint to
# different digests, lighting up a "config mismatch" badge on the
# dashboard. Keep the string deterministic — same flags, same order.
SLOPGATE_DIGEST_EXTRA=kv=q8_0 np=4 b=2048 ub=1024
