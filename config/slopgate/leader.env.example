# Slopgate leader-node configuration. Copy to ~/.config/slopgate/leader.env
# and fill in the placeholder values for THIS host. The real file is
# git-ignored — never commit it.
#
# This is the box that runs the slopgate balancer. It also runs its own
# llama-server on the loopback (the launcher flips to 127.0.0.1:8081 when
# the slopgate-balancer plist/unit is installed) and registers it with the
# balancer through a co-located slopgate-agent.

# --- Balancer (reverse proxy in front of the cluster) -----------------------
SLOPGATE_REVERSEPROXY_ADDR=0.0.0.0:8080
SLOPGATE_MANAGEMENT_ADDR=0.0.0.0:8085

# --- Local llama-server agent (this host) -----------------------------------
SLOPGATE_LOCAL_AGENT_NAME=leader
SLOPGATE_LOCAL_LLAMACPP_ADDR=127.0.0.1:8081
SLOPGATE_LLAMACPP_REQUEST_TIMEOUT=120
SLOPGATE_LOCAL_MAX_CONTEXT=131072
SLOPGATE_LOCAL_MODEL_ALIAS=qwen

# Machine class shared by physically identical hosts. Leave empty to fall
# back to the host's machine_id. See sloppy-org/slopgate README, section
# "Model naming convention".
SLOPGATE_LOCAL_MACHINE_PROFILE=mac-studio-m3-ultra-256g

# Canonical model identity at the weights-family + context level
# (vendor/family:size-variant@ctx). Two peers serving the same family at
# the same context but different quants share this canonical and are
# distinguished by SLOPGATE_LOCAL_QUANT below.
SLOPGATE_LOCAL_CANONICAL_MODEL=unsloth/qwen3.6:35b-a3b@128k

# Quant label this peer is serving. Informational; not used for routing.
# Faepmac1 (Mac Studio / Metal) defaults to the heavier XL; Linux PC and
# follower defaults are UD-IQ4_XS. See ../docs/iq4_xs-rollout.md.
SLOPGATE_LOCAL_QUANT=UD-Q4_K_XL

# Comma-separated extra routing aliases this agent answers to in addition
# to the canonical and SLOPGATE_LOCAL_MODEL_ALIAS.
SLOPGATE_LOCAL_MODEL_ALIASES=35b,35b@128k,Q4

# Load-bearing llama-server launch flags not visible in /props. Folded
# into config_digest. Keep deterministic across hosts.
SLOPGATE_LOCAL_DIGEST_EXTRA=kv=q8_0 np=4 b=2048 ub=1024
