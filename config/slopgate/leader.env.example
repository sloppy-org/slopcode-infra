# Slopgate leader-node configuration. Copy to ~/.config/slopgate/leader.env
# and fill in the placeholder values for THIS host. The real file is
# git-ignored — never commit it.
#
# This is the box that runs the slopgate balancer. It also runs its own
# llama-server on the loopback (the launcher flips to 127.0.0.1:8081 when
# the slopgate-balancer plist/unit is installed) and registers it with the
# balancer through a co-located slopgate-agent.

# --- Balancer (reverse proxy in front of the cluster) -----------------------
SLOPGATE_REVERSEPROXY_ADDR=0.0.0.0:8080
SLOPGATE_MANAGEMENT_ADDR=0.0.0.0:8085

# --- Local llama-server agent (this host) -----------------------------------
SLOPGATE_LOCAL_AGENT_NAME=leader
SLOPGATE_LOCAL_LLAMACPP_ADDR=127.0.0.1:8081
SLOPGATE_LLAMACPP_REQUEST_TIMEOUT=120
SLOPGATE_LOCAL_MAX_CONTEXT=262144
SLOPGATE_LOCAL_MODEL_ALIAS=qwen
