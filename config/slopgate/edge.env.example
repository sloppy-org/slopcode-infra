# Slopgate edge-agent configuration. Copy to ~/.config/slopgate/edge.env and
# fill in the placeholder values for THIS host and YOUR edge balancer. The
# real file is git-ignored; never commit it.
#
# An edge agent registers this host's local llama-server with a separate edge
# balancer's management endpoint over WireGuard, tagged with a privacy tier.
# It lets a local model join an edge endpoint that also fronts other
# providers. This is independent of the leader cluster: an edge agent points
# at the edge balancer, never at the leader.

# The edge balancer's management address. Use its WireGuard / LAN IP, not a
# public hostname.
SLOPGATE_EDGE_MANAGEMENT_ADDR=10.0.0.1:8089

# How the agent reaches the local llama-server, and how the edge balancer
# reaches it for forwarding. On a host that binds llama-server to its
# WireGuard IP directly, both are that WG IP; on a loopback-bound host the
# local addr is 127.0.0.1:8080 and the external addr is the WG IP.
SLOPGATE_LOCAL_LLAMACPP_ADDR=10.0.0.2:8080
SLOPGATE_EXTERNAL_LLAMACPP_ADDR=10.0.0.2:8080
SLOPGATE_LLAMACPP_REQUEST_TIMEOUT=120

# Friendly name shown on the edge dashboard. Keep it distinct from any
# leader-follower agent name on the same host so the two roles never collide.
SLOPGATE_AGENT_NAME=edge-agent-1

# Stable class name shared by physically identical hosts (see follower.env).
SLOPGATE_MACHINE_PROFILE=linux-host

SLOPGATE_MAX_CONTEXT=131072
SLOPGATE_CANONICAL_MODEL=unsloth/qwen3.6:35b-a3b@128k
SLOPGATE_QUANT=UD-Q4_K_XL-MTP
SLOPGATE_MODEL_ALIAS=qwen
SLOPGATE_MODEL_ALIASES=35b,35b@128k,Q4
SLOPGATE_DIGEST_EXTRA=kv=q8_0 np=1 b=2048 ub=512

# Privacy tier this peer serves: local|private|trusted|public. Models running
# on your own hardware are `local`.
SLOPGATE_PRIVACY_LEVEL=local
