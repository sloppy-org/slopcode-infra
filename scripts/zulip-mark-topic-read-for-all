#!/usr/bin/env bash
# Mark every UserMessage row for a Zulip (stream, topic) read for all
# subscribers. Wrapper that delegates to manage.py shell (which sets up
# the Zulip venv + DJANGO_SETTINGS_MODULE on its own) under the zulip
# user. Called by the slopgate / computor watchdog when an incident topic
# is fully green so everyone's unread count clears, not just the bot's.
#
# Topic is passed via environment to sidestep nested shell quoting around
# Unicode (✔) and space-bearing topic names.
set -euo pipefail

if [[ $# -ne 2 ]]; then
    echo "usage: $0 STREAM TOPIC" >&2
    exit 2
fi
stream="$1"
topic="$2"

# Stream is a plain identifier on Zulip. Topic is permissive — Zulip itself
# allows almost anything — so we only reject newline / carriage return
# which would break the env-var transport.
if [[ ! "$stream" =~ ^[A-Za-z0-9._-]+$ ]]; then
    echo "invalid stream: $stream" >&2
    exit 2
fi
case "$topic" in
    *$'\n'*|*$'\r'*) echo "invalid topic (control char)" >&2; exit 2 ;;
esac

DEPLOYMENT="${ZULIP_DEPLOYMENT:-/home/zulip/deployments/current}"
MANAGE_PY="$DEPLOYMENT/manage.py"
SCRIPT_DIR="${ZULIP_HELPER_DIR:-/usr/local/lib/slopgate-watchdog}"
SCRIPT_PATH="$SCRIPT_DIR/zulip_mark_topic_read_for_all.py"

if [[ ! -x "$MANAGE_PY" ]]; then
    echo "zulip manage.py not found: $MANAGE_PY" >&2
    exit 4
fi
if [[ ! -r "$SCRIPT_PATH" ]]; then
    echo "helper script not found: $SCRIPT_PATH" >&2
    exit 4
fi

# Run as zulip. Pass args through env to avoid quoting headaches; the
# helper raises if either is missing. manage.py shell --command runs the
# string as Python after Django setup.
export ZULIP_STREAM_ARG="$stream"
export ZULIP_TOPIC_ARG="$topic"
exec su -s /bin/bash zulip -c \
    "ZULIP_STREAM_ARG=$(printf '%q' "$stream") ZULIP_TOPIC_ARG=$(printf '%q' "$topic") \
     $(printf '%q' "$MANAGE_PY") shell --command \
     $(printf '%q' "exec(open('$SCRIPT_PATH').read())")"
